syntax = "v1"


@server(
    group: course/class
    prefix: /api/v1/course/class
    jwt: Auth
)
service gateway {
    @handler CreateClass
    post /

    @handler ListClass
    get /

    @handler UpdateClass
    put /:id

    @handler DeleteClass
    delete /:ids

    @handler FindClass
    get /:id
}
