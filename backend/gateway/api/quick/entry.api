syntax = "v1"


@server(
    group: quick/entry
    prefix: /api/v1/quick/entry
    jwt: Auth
)
service gateway {
    @handler CreateEntry
    post /

    @handler ListEntry
    get /

    @handler UpdateEntry
    put /:id

    @handler DeleteEntry
    delete /:ids

    @handler FindEntry
    get /:id
}
